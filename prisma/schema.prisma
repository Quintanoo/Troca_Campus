generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  TRADED
  INACTIVE
}

enum ProductCondition {
  NEW
  USED
  GOOD
  FAIR
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  campus       String?
  phone        String?
  reputation   Float      @default(0)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  products     Product[]

  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())

  products  Product[]

  @@map("categories")
}

model Product {
  id          String           @id @default(uuid())
  userId      String
  categoryId  String
  title       String
  description String
  condition   ProductCondition
  status      ProductStatus    @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id])
  category    Category         @relation(fields: [categoryId], references: [id])

  @@map("products")
}