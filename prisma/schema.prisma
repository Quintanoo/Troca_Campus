generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  TRADED
  INACTIVE
}

enum ProductCondition {
  NEW
  USED
  GOOD
  FAIR
}

enum TradeStatus {
  PENDING
  ACCEPTED
  CANCELED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  campus       String?
  phone        String?
  reputation   Float      @default(0)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  products     Product[]
  sentTrades Trade[] @relation("RequesterTrades")
  messages Message[]

  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())

  products  Product[]

  @@map("categories")
}

model Product {
  id          String           @id @default(uuid())
  userId      String
  categoryId  String
  title       String
  description String
  condition   ProductCondition
  status      ProductStatus    @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id])
  category    Category         @relation(fields: [categoryId], references: [id])
  photos      ProductPhoto[]
  trades Trade[]

  @@map("products")
}

model ProductPhoto {
  id        String   @id @default(uuid())
  productId String
  url       String
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_photos")
}

model Trade {
  id          String      @id @default(uuid())
  requesterId String
  productId   String
  status      TradeStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  requester   User        @relation("RequesterTrades", fields: [requesterId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
  messages Message[]

  @@map("trades")
}

model Message {
  id        String   @id @default(uuid())
  tradeId   String
  senderId  String
  text      String
  createdAt DateTime @default(now())

  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

  @@map("messages")
}